        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const days = Math.floor(difference / (1000 * 60 * 60 * 24));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const hours = Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const minutes = Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const seconds = Math.floor((difference % (1000 * 60)) / 1000);"
