        }
        lines {
          text: "export const SONGS: Song[] = ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'song-1\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    title: \'Kukiliyon of Saint Mary (Kanyaka Mariam)\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'Hymns of Saint Mary\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    englishTitle: \'Intercession Hymn of the Virgin Mary\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    lyricsEnglish: `Let us honor Mary, the mother of our Lord,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "A fertile harbor and beautiful ship of our faith,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Who carried the Savior who bears the universe."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "All generations shall call her blessed,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "As she prayed with devotion,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "\"May your mercy fall upon this creation of yours.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "O Lord, by her prayers, save our souls!`,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    lyricsTransliterated: `Mariyaam parayunnu: en nalloru vaalilaaye,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Srishtaave! nin srishtikalil kripayundu aakaname."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Bhagyam janaloke, ninne chonnidumennennekkum."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Ninte thirunaamam kondaadine nannaye raajyam,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Kripa nalkuka naadha, ninnude kripayaal njangal,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Vaazhthuka ninkripaye, ennum thirumunpil thunayaay,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Devamaathaave, njangalkkayi nee thunayaaname...`,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    keyNotes: \'Sung during liturgical incenses and Kukiliyons in ancient Tone 8 layout. Revering Saint Mary\342\200\231s maternal custody.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    tempo: \'Solemn 80 BPM\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'song-2\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    title: \'Yajamanan Varum Nerathu (The Alert Servants)\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'Liturgical Chants\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    englishTitle: \'Blessed Are Those Servants\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    lyricsEnglish: `Blessed are those servants whom the Master,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "When He comes, shall find awake and alert!"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "He will gird Himself, make them sit at meat,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "And serve them with eternal provisions."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "The Father will bless, the Son will serve,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "The Holy Spirit will weave beautiful crowns for them."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Hallelujah, yes, blessed are those faithful souls!`,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    lyricsTransliterated: `Yajamanan varumnerath-unarnnirikkunnor-aam,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Nalladasare dhaanathil kandaal bhagyametram!"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Aaranju thalaridathe nirayittu nirathee,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Yajamanan thaan-avarude arikil poy paricharikkum."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Pithavu avarude sreshtha thalaonnu thalodum,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Puthran-avarkku pathram nalki kripaye thookum,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Ruha dhivyamaan-avarkkaayi mudikal korukkum,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Haleluyah, vaazhthuka njaan sreshtha manushyane!`,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    keyNotes: \'A classic Vigil/Kaltha hymn from the ancient Syrian Antiochian Liturgical cycle representing spiritual wakefulness.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    tempo: \'Chanted, Free Tempo\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'song-3\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    title: \'Anpudayone Nin Vaathil (Merciful Lord)\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'Liturgical Chants\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    englishTitle: \'O Merciful Lord, Open Thy Door of Mercy\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    lyricsEnglish: `O Merciful Lord, open Your gate to us,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Sinner souls who call upon Your great name!"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Through Your abundant grace, answer our sighs,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Do not turn us away from your high throne."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Save us from spiritual failures and biological diseases,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Pour Your peaceful oils upon our anxious hearts."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Glorified be Your name, from ages to ages!`,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
